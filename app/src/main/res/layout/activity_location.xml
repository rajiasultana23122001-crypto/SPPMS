<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ECECEC">

    <LinearLayout
        android:id="@+id/locationContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Child Location"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvChildName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Name: Ethan Ibne Ferdous"
                android:textSize="22sp"
                android:textColor="#000000" />

            <TextView
                android:id="@+id/tvChildEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email: ehan@gmail.com"
                android:textSize="20sp"
                android:textColor="#000000" />

            <TextView
                android:id="@+id/tvLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Location: 23.8100877, 90.3556386"
                android:textSize="20sp"
                android:textColor="#000000"
                android:layout_marginTop="8dp" />

            <Button
                android:id="@+id/btnViewLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="VIEW LOCATION"
                android:layout_marginTop="16dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>